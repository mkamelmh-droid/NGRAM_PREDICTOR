# Environment variables for NGram Predictor
# Edit these paths and values for your local setup

# Data directories
TRAIN_RAW_DIR=data/raw/train/
EVAL_RAW_DIR=data/raw/eval/

# Processed data files
TRAIN_TOKENS=data/processed/train_tokens.txt
EVAL_TOKENS=data/processed/eval_tokens.txt

# Model files
MODEL=data/model/model.json
VOCAB=data/model/vocab.json

# Model parameters
UNK_THRESHOLD=1
TOP_K=5
NGRAM_ORDER=4

# Optional logging
# LOG_LEVEL=INFO
